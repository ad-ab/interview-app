# ─── Monorepo root ────────────────────────────────────────────────────────────
#
# Per-package .gitignore files live in apps/web, apps/api and packages/shared
# — this file only covers things that are workspace-root level or cross-cutting.

# Node dependencies (pnpm, npm, yarn) — never commit, any workspace
node_modules/

# Rust / Cargo build artifacts (workspace target/ lives at repo root)
target/

# Lockfiles from the wrong package manager (this repo is pnpm-managed)
package-lock.json
yarn.lock

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Env / secrets
.env
.env.*
!.env.example

# Caches
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache

# Coverage
coverage/
*.lcov
.nyc_output/

# Editor / IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
*~

# Claude Code workspace files
.claude/
.superpowers/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
